# Runtime org data (created by /onboard — unique per user)
org/

# Runtime-created agent definitions (created by CAO during operation)
# Only the 3 template agents (ceo.md, cao.md, alignment-board.md) are tracked
.claude/agents/*
!.claude/agents/ceo.md
!.claude/agents/cao.md
!.claude/agents/alignment-board.md

# Dependencies
node_modules/

# User-specific Claude Code settings
.claude/settings.local.json
.claude/agent-memory/
.claude/agent-memory-local/

# OS
.DS_Store
Thumbs.db

# Browser profiles (login state, sensitive)
org/.browser-profiles/

# Live feed (transient, regenerated by hooks)
org/.live-feed.log

# Temp
*.tmp
*.swp

# Distribution build artifacts
create-orgagent/template/
